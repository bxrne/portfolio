---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { READING } from "@consts";

const readings = (await getCollection("reading"))
  .filter(reading => !reading.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PageLayout title={READING.TITLE} description={READING.DESCRIPTION}>
  <div class="space-y-10 pt-8 md:pt-16">
    <div>
      <h2 class="font-serif text-2xl font-bold mb-2">Reading</h2>
      <p class="text-paper-muted">{READING.DESCRIPTION}</p>
    </div>
    <div>
      {readings.map((reading) => (
        <ArrowCard entry={reading} />
      ))}
    </div>
  </div>
</PageLayout>
