---
import type { CollectionEntry } from "astro:content";
import { readingTime } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"blog"> | CollectionEntry<"projects"> | CollectionEntry<"reading">;
}

const { entry } = Astro.props;
---

<a href={entry.collection === "reading" ? entry.data.url : `/${entry.collection}/${entry.slug}`} class="group block py-2.5">
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
    <div class="text-paper-fg group-hover:text-paper-muted transition-colors">
      {entry.data.title}
    </div>
    <div class="text-sm text-paper-muted shrink-0">
      {entry.collection === "reading"
        ? entry.data.author
        : readingTime(entry.body)
      }
    </div>
  </div>
  <div class="text-sm text-paper-muted mt-0.5">
    {entry.collection === "reading"
      ? (entry.data.tags ? entry.data.tags.join(", ") : "")
      : entry.data.description
    }
  </div>
</a>
