---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="mb-8 border border-paper-border rounded-lg p-4">
    <h2 class="font-serif text-sm font-semibold text-paper-muted uppercase tracking-wide mb-2">Contents</h2>
    <ul class="space-y-1 text-sm">
      {filteredHeadings.map((heading) => (
        <li class={heading.depth === 3 ? "pl-4" : ""}>
          <a
            href={`#${heading.slug}`}
            class="text-paper-fg hover:text-paper-muted underline-offset-2 hover:underline"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
